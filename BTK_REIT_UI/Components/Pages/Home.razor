@page "/"
@layout BTK_REIT_UI.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject HttpClient Http
@inject NavigationManager Nav
@inject BTK_REIT_UI.Services.AuthService AuthService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@using BTK_REIT_Shared.DTOs
@using System.Net

<PageTitle>Sign In — BTK REIT</PageTitle>

<div class="reit-login-backdrop">
    <div class="reit-login-card">

        @* Brand header *@
        <div class="reit-login-brand">
            <div class="reit-login-icon">
                <svg fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" width="28" height="28">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
            </div>
            <div>
                <div class="reit-login-title">BTK REIT</div>
                <div class="reit-login-subtitle">Management System</div>
            </div>
        </div>

        <h2 class="reit-login-heading">Sign in to your account</h2>

        @* Error alert *@
        @if (errorMessage is not null)
        {
            <div class="reit-login-alert">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="16" height="16">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
                @errorMessage
            </div>
        }

        @* Login form *@
        <EditForm Model="loginModel" OnValidSubmit="HandleLoginAsync" novalidate>
            <DataAnnotationsValidator />

            <div class="reit-login-field">
                <label class="reit-login-label" for="username">Username</label>
                <InputText id="username"
                           class="reit-login-input"
                           placeholder="Enter your username"
                           @bind-Value="loginModel.UserName"
                           autocomplete="username" />
                <ValidationMessage For="() => loginModel.UserName" class="reit-login-validation" />
            </div>

            <div class="reit-login-field">
                <label class="reit-login-label" for="password">Password</label>
                <InputText id="password"
                           type="@(showPassword ? "text" : "password")"
                           class="reit-login-input"
                           placeholder="Enter your password"
                           @bind-Value="loginModel.Password"
                           autocomplete="current-password" />
                <ValidationMessage For="() => loginModel.Password" class="reit-login-validation" />
                <label class="reit-login-show-pw">
                    <input type="checkbox" @bind="showPassword" />
                    Show password
                </label>
            </div>

            <button type="submit" class="reit-login-btn" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Signing in&hellip;</span>
                }
                else
                {
                    <span>Sign In</span>
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="16" height="16">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                }
            </button>
        </EditForm>

        <p class="reit-login-footer">BTK Real Estate Investment Trust &copy; 2025</p>
    </div>
</div>

@code {
    private readonly LoginRequest loginModel = new();
    private string? errorMessage;
    private bool isLoading;
    private bool showPassword;

    protected override async Task OnInitializedAsync()
    {
        // If already authenticated, skip login
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            Nav.NavigateTo("/properties", replace: true);
    }

    private async Task HandleLoginAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                errorMessage = "Invalid username or password. Please try again.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Login failed ({(int)response.StatusCode}). Please try again.";
                return;
            }

            var session = await response.Content.ReadFromJsonAsync<UserSession>();
            if (session is null)
            {
                errorMessage = "Unexpected server response. Please try again.";
                return;
            }

            await AuthService.LoginAsync(session);
            Nav.NavigateTo("/properties", replace: true);
        }
        catch (HttpRequestException)
        {
            errorMessage = "Cannot reach the API. Ensure the BTK REIT engine is running.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
