@page "/shareholders"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav
@using BTK_REIT_Shared.DTOs

<PageTitle>Shareholders — BTK REIT</PageTitle>

@* ── Page header ── *@
<div class="reit-page-header">
    <div>
        <h1 class="reit-page-title">Shareholders</h1>
        <p class="reit-page-subtitle">Registered investors and KYC records</p>
    </div>
    @if (shareholders is not null)
    {
        <span class="reit-count-pill">
            <span class="reit-count-dot"></span>
            @shareholders.Count record@(shareholders.Count == 1 ? "" : "s")
        </span>
    }
</div>

@* ── Error state ── *@
@if (errorMessage is not null)
{
    <div class="reit-error mb-4">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
        </svg>
        <div>
            <p class="reit-error-title">Could not load shareholders</p>
            <p class="mb-0">@errorMessage</p>
        </div>
    </div>
}

@* ── Loading state ── *@
@if (shareholders is null && errorMessage is null)
{
    <div class="reit-card">
        <div class="reit-loading">
            <div class="spinner-border spinner-border-sm text-secondary mb-2" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mb-0">Loading shareholders&hellip;</p>
        </div>
    </div>
}
@* ── Data table ── *@
else if (shareholders is not null)
{
    <div class="reit-card">
        <div class="reit-table-wrap">
            <table class="reit-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Type</th>
                        <th>Contact</th>
                        <th>Email</th>
                        <th>CNIC</th>
                        <th>Status</th>
                        <th>Since</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sh in shareholders)
                    {
                        <tr>
                            <td class="mono text-muted-sm">@sh.ShId</td>
                            <td class="fw-semibold">@sh.FullName</td>
                            <td class="text-muted-sm">@sh.UserName</td>
                            <td>
                                <span class="badge-soft badge-inactive">@sh.ShType</span>
                            </td>
                            <td class="mono">@sh.ContactNo</td>
                            <td class="text-muted-sm">@sh.ContactEmail</td>
                            <td class="mono text-muted-sm">@(sh.Cnic ?? "—")</td>
                            <td>
                                <span class="badge-soft @GetStatusBadgeClass(sh.Status)">@sh.Status</span>
                            </td>
                            <td class="mono text-muted-sm">@sh.CreationDate.ToShortDateString()</td>
                            <td>
                                <button class="reit-btn reit-btn--ghost reit-btn--sm"
                                        @onclick="() => GoToDetail(sh.ShId)">
                                    View / Edit
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<ShareholderDto>? shareholders;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            shareholders = await Http.GetFromJsonAsync<List<ShareholderDto>>("api/shareholders");
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"API unreachable — {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void GoToDetail(int id) => Nav.NavigateTo($"/shareholders/{id}");

    private static string GetStatusBadgeClass(string status) => status.ToLower() switch
    {
        "active"    => "badge-active",
        "pending"   => "badge-pending",
        "suspended" => "badge-suspended",
        "inactive"  => "badge-inactive",
        _           => "badge-inactive"
    };
}
