@inherits LayoutComponentBase

<div class="reit-layout">
    <nav class="reit-sidebar">
        <NavMenu />
    </nav>

    <div class="reit-content-wrap">
        <header class="reit-topbar">
            <span class="reit-topbar-title">BTK REIT Management System</span>
            <span class="reit-topbar-badge">v1.1</span>
        </header>

        <main class="reit-main px-4 py-3">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>
