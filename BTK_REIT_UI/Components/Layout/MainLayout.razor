@inherits LayoutComponentBase

<div class="reit-layout">

    @* ── Sidebar ── *@
    <aside class="reit-sidebar">

        @* Brand *@
        <div class="reit-brand">
            <div class="reit-brand-icon">
                <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
                </svg>
            </div>
            <div>
                <div class="reit-brand-name">BTK REIT</div>
                <div class="reit-brand-sub">Management System</div>
            </div>
        </div>

        @* Nav *@
        <div class="reit-nav-scroll">
            <NavMenu />
        </div>

        @* Footer *@
        <div class="reit-sidebar-footer">
            <span>v1.1.0</span>
        </div>
    </aside>

    @* ── Main area ── *@
    <div class="reit-content-wrap">

        @* Top bar *@
        <header class="reit-topbar">
            <span class="reit-topbar-title">BTK REIT Management System</span>
            <div class="reit-topbar-right">
                <span class="reit-topbar-badge">Live</span>
                <TopbarUser />
            </div>
        </header>

        @* Page content *@
        <main class="reit-main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="ms-2 fw-semibold text-white">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>
